{
  "name": "amega-capital",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android:generate:codegen": "cd android && ./gradlew generateCodegenArtifactsFromSchema --rerun-tasks && cd ..",
    "sentry:disable": "export SENTRY_DISABLE_AUTO_UPLOAD=true",
    "clean": "rimraf ./ios/Podfile.lock && rimraf ./ios/Pods && rimraf ./android/build && rimraf ./android/app/.cxx && rimraf ./android/app/build && rimraf ./package-lock.json && rimraf ./yarn.lock && rimraf ./node_modules",
    "android:clean:build": "rimraf ./android/build && rimraf ./android/app/.cxx && rimraf ./android/app/build",
    "design:token": "node scripts/design-tokens-transformer",
    "setup": "npm i && npm run design:token && cd ios && pod install --repo-update && cd .. && watchman watch-del-all",
    "start": "watchman watch-del-all && react-native start --reset-cache",
    "ios": "react-native run-ios --list-devices",
    "ios:bundle": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ./ios",
    "ios:dev": "export ENVFILE=.env.development && react-native run-ios --mode=Debug --scheme \"amegaCapitalDev\"",
    "ios:dev:list": "export ENVFILE=.env.development && react-native run-ios --list-devices --mode=Debug --scheme \"amegaCapitalDev\"",
    "ios:dev:ipa": "export ENVFILE=.env.development && react-native run-ios --mode=Release --scheme \"amegaCapitalDev\"",
    "android:bundle": "react-native bundle --entry-file index.js --platform android --dev false --bundle-output android/main.jsbundle --assets-dest android/assets",
    "android:clean": "npm run android:clean:build && cd android && ./gradlew --stop && ./gradlew clean && ./gradlew generateCodegenArtifactsFromSchema --rerun-tasks",
    "android:dev": "export ENVFILE=.env.development && npm run android:clean && npx react-native run-android --mode=devDebug --appId=\"com.amega.capital.development\"",
    "android:qa": "export ENVFILE=.env.qa && npm run android:clean && npx react-native run-android --mode=qaDebug --appId=\"com.amega.capital.qa\"",
    "android:stage": "export ENVFILE=.env.staging && npm run android:clean && npx react-native run-android --mode=stageDebug --appId=\"com.amega.capital.staging\"",
    "android:prod": "export ENVFILE=.env.production && npm run android:clean && npx react-native run-android --mode=prodDebug --appId=\"com.amega.capital.trading\"",
    "android": "npm run android:dev",
    "android:build:aab:dev": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.development && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon bundleDevRelease",
    "android:build:aab:qa": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.qa && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon bundleQaRelease",
    "android:build:aab:stage": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.staging && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon bundleStageRelease",
    "android:build:aab:prod": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.production && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon bundleProdRelease",
    "android:build:apk:dev": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.development && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon assembleDevRelease",
    "android:build:apk:qa": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.qa && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon assembleQaRelease",
    "android:build:apk:qa:debug": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.qa && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon assembleQaDebug",
    "android:build:apk:stage": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.staging && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon assembleStageRelease",
    "android:build:apk:prod": "export SENTRY_DISABLE_AUTO_UPLOAD=true && export ENVFILE=.env.production && npm run android:clean && cd android && ./gradlew --stop && ./gradlew --stacktrace --no-daemon assembleProdRelease",
    "android:install:apk:dev": "npm run android:build:apk:dev && adb install -r ./android/app/build/outputs/apk/dev/release/app-dev-release.apk",
    "android:install:apk:qa": "npm run android:build:apk:qa && adb install -r ./android/app/build/outputs/apk/qa/release/app-qa-release.apk",
    "android:install:apk:qa:debug": "npm run android:build:apk:qa:debug && adb install -r ./android/app/build/outputs/apk/qa/debug/app-qa-debug.apk",
    "android:install:apk:stage": "npm run android:build:apk:stage && adb install -r ./android/app/build/outputs/apk/stage/release/app-stage-release.apk",
    "android:install:apk:prod": "npm run android:build:apk:prod && adb install -r ./android/app/build/outputs/apk/prod/release/app-prod-release.apk",
    "android:cleanWindows": "cd android && gradlew.bat --stop && gradlew.bat clean",
    "android:devWindows": "set ENVFILE=.env.development && npm run android:cleanWindows && npx react-native run-android --mode=devDebug --appId=\"com.amega.capital.development\"",
    "androidWindows": "npm run android:devWindows",
    "logcat": "adb logcat *:S ReactNative:V ReactNativeJS:V",
    "app:dev": "cd android && ./gradlew appDistributionUploadDevRelease --releaseNotes \"Test upload\" --appId \"1:922508707079:android:eca74cbd605071c1e2b1a2\" && cd ..",
    "app:qa": "cd android && ./gradlew appDistributionUploadQaRelease --releaseNotes \"Test upload\" --appId \"1:922508707079:android:bf4b6fc216c03cace2b1a2\" && cd ..",
    "app:stage": "cd android && ./gradlew appDistributionUploadStageRelease --releaseNotes \"Test upload\" --appId \"1:922508707079:android:89224530877b2e53e2b1a2\" && cd ..",
    "app:prod": "cd android && ./gradlew appDistributionUploadProdRelease --releaseNotes \"Test upload\" --appId \"1:922508707079:android:1e7e758901837645e2b1a2\" && cd ..",
    "app:publish:dev": "cd android && ./gradlew publishDevReleaseBundle --track internal --release-status draft --stacktrace --info",
    "logcat:clean": "adb logcat -c",
    "logcat:crash": "adb logcat -b crash",
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint .",
    "test": "jest",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,json}\"",
    "prepare": "husky install",
    "postinstall": "npx typesync && patch-package",
    "precommit": "",
    "upload:translations": "simplelocalize upload",
    "download:translations": "simplelocalize download",
    "deeplinks": "node scripts/command.mjs",
    "prestart": "for d in $(adb devices | grep -w device | awk '{print $1}'); do adb -s $d reverse tcp:9090 tcp:9090; done",
    "tcp": "for d in $(adb devices | grep -w device | awk '{print $1}'); do adb -s $d reverse tcp:9090 tcp:9090; done"
  },
