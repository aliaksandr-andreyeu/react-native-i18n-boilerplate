{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "sourceMap": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "isolatedModules": true
  },
  "exclude": [
    ".vscode",
    "assets",
    "android",
    "ios",
    "node_modules",
    "patches",
    "react-native.config.js",
    "jest.config.js",
    "metro.config.js"
  ]
}
